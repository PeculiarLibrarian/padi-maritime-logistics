@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix padi: <http://example.org/schema#> .

padi:MarketLedgerShape
    a sh:NodeShape ;
    sh:targetClass padi:MarketLedger ;

    sh:property [
        sh:path padi:status ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path padi:balance_usd ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
    ] ;

    sh:property [
        sh:path padi:logic ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
    ] .

