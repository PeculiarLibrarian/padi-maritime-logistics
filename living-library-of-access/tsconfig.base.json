{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@padi/crypto": ["packages/crypto/src"],
      "@padi/ledger": ["packages/ledger/src"],
      "@padi/validator": ["packages/validator/src"],
      "@padi/schema": ["packages/schema/src"],
      "@padi/p2p": ["packages/p2p/src"]
    }
  }
}
